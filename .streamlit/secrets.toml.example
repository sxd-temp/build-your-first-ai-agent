# --- How to provide your Gemini API key ---
#
# On Streamlit Community Cloud (for the deploy step):
#   App → Settings → Secrets → paste the line below (with your real key).
#
# In Codespaces / locally:
#   Easier to copy .env.example to .env and put your key there instead.
#
GEMINI_API_KEY = "paste-your-gemini-key-here"
